# Qualitas Backend Environment Template
# 複製此檔案為 .env 並填入實際值

# Environment (development, staging, production)
ENVIRONMENT=development

# JWT 設定
# CRITICAL: Generate a strong random secret key (minimum 32 characters)
# You can generate one using: python -c "import secrets; print(secrets.token_urlsafe(32))"
# NEVER use the default value in production!
SECRET_KEY=your-strong-secret-key-here-minimum-32-characters-required
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# 資料庫設定 (如需自訂)
# DATABASE_URL=sqlite:///./qualitas.db

# Initial Admin Setup (Only used on first run when database is empty)
# These credentials will be used to create the first admin user
# CHANGE THESE IMMEDIATELY AFTER FIRST LOGIN
INITIAL_ADMIN_EMAIL=admin@example.com
INITIAL_ADMIN_PASSWORD=
